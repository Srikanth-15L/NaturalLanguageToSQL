# Groq API key (required for the SQL agent)
# Get yours free at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Tavily search API key (optional, used for web search tool demos)
# Free tier available at https://tavily.com
TAVILY_API_KEY=tvly-dev-your_tavily_api_key_here

# WeatherAPI key (optional, used in the live demo notebook)
# Free tier available at https://www.weatherapi.com
WEATHER_API_KEY=your_weather_api_key_here
